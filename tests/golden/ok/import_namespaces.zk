# RUN: --public expected=13 --public gate=true --private x=5 --private y=1
# EXPECT-OUTPUT: result=13
circuit import_namespaces {
    import "support/imports/left.zk" as left;
    import "support/imports/right.zk" as right;

    public expected: field;
    public gate: bool;
    private x: field;
    private y: field;

    let result = left::score(x, gate) + right::score(y, gate);
    constrain result == expected;
    expose result;
}
